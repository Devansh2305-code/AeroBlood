# =========================================================================
# AeroBlood Production Environment Variable Declarations
# =========================================================================

# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="MY_APP_URL"

# SUPABASE_URL: The secure URL endpoint of your Supabase project backend.
SUPABASE_URL="https://your-supabase-project-id.supabase.co"

# SUPABASE_ANON_KEY: Client-safe Supabase API key enabling CRUD operations.
SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-token"

# SUPABASE_SERVICE_ROLE_KEY: Master server secret key bypassing RLS policies.
# WARNING: NEVER expose this key in client-side code bundles!
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-token"

# GOOGLE_MAPS_API_KEY: Geocoding, Places and Maps SDK client-safe API token.
GOOGLE_MAPS_API_KEY="AIzaSyYourGoogleMapsApiKey"

# FIREBASE_MESSAGING_SENDER_ID: Sender ID for push notification routing via FCM.
FIREBASE_MESSAGING_SENDER_ID="your-firebase-messaging-sender-id"

# FIREBASE_SERVICE_ACCOUNT_JSON: Service Account credentials (base64 encoded JSON string) 
# required to authenticate and push SOS notifications using the modern FCM HTTP v1 API.
FIREBASE_SERVICE_ACCOUNT_JSON="eyJ0eXBlIjogInNlcnZpY2VfYWNjb3VudCIsICJwcm9qZWN0X2lkIjogImFlcm9ibG9vZCIsIC4uLn0="
